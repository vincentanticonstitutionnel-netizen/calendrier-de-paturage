// Define common French projections for proj4
proj4.defs([
  ['EPSG:2154', '+proj=lcc +lat_1=49 +lat_2=44 +lat_0=46.5 +lon_0=3 +x_0=700000 +y_0=6600000 +ellps=GRS80 +towgs84=0,0,0,0,0,0,0 +units=m +no_defs'], // Lambert 93
  ['EPSG:27572', '+proj=lcc +lat_1=46.8 +lat_0=46.8 +lon_0=0 +k_0=0.99987742 +x_0=600000 +y_0=2200000 +a=6378249.2 +b=6356515 +towgs84=-168,-60,320,0,0,0,0 +pm=paris +units=m +no_defs'], // Lambert II étendu (ancien Télépac)
  ['EPSG:4326', '+proj=longlat +datum=WGS84 +no_defs'],
  ['EPSG:3857', '+proj=merc +a=6378137 +b=6378137 +lat_ts=0 +lon_0=0 +x_0=0 +y_0=0 +k=1 +units=m +nadgrids=@null +wktext +no_defs'],
]);

function detectAndReproject(rings) {
  // Find bounding box of all rings
  let minX = Infinity, maxX = -Infinity, minY = Infinity, maxY = -Infinity;
  rings.forEach(r => r.forEach(p => {
    if (p[0] < minX) minX = p[0];
    if (p[0] > maxX) maxX = p[0];
    if (p[1] < minY) minY = p[1];
    if (p[1] > maxY) maxY = p[1];
  }));
  // Already lon/lat?
  if (minX >= -180 && maxX <= 180 && minY >= -90 && maxY <= 90) {
    return { rings, projection: 'WGS84 (lon/lat)' };
  }
  // Try Lambert-93: typical X range 0–1300000, Y range 6000000–7200000 for metropolitan France
  if (minX > 0 && maxX < 1300000 && minY > 6000000 && maxY < 7200000) {
    const reproj = rings.map(r => r.map(p => proj4('EPSG:2154', 'EPSG:4326', [p[0], p[1]])));
    return { rings: reproj, projection: 'Lambert-93 → WGS84' };
  }
  // Lambert II étendu (ancien) : X 0–1200000, Y 1500000–2700000
  if (minX > 0 && maxX < 1200000 && minY > 1500000 && maxY < 2800000) {
    const reproj = rings.map(r => r.map(p => proj4('EPSG:27572', 'EPSG:4326', [p[0], p[1]])));
    return { rings: reproj, projection: 'Lambert II étendu → WGS84' };
  }
  // Web Mercator (3857): X large in meters, Y in meters too
  if (Math.abs(maxX) < 2.1e7 && Math.abs(maxY) < 2.1e7 && (Math.abs(maxX) > 180 || Math.abs(maxY) > 90)) {
    const reproj = rings.map(r => r.map(p => proj4('EPSG:3857', 'EPSG:4326', [p[0], p[1]])));
    return { rings: reproj, projection: 'Web Mercator → WGS84' };
  }
  return { rings: null, projection: null, error: `coordonnées hors plage connue (X: ${minX.toFixed(0)}…${maxX.toFixed(0)}, Y: ${minY.toFixed(0)}…${maxY.toFixed(0)})` };
}

function handleImportedGeoJSON(geo, isTelepac) {
  let features = [];
  const collect = (g) => {
    if (!g) return;
    if (Array.isArray(g)) { g.forEach(collect); return; }
    if (g.type === 'FeatureCollection') features.push(...g.features);
    else if (g.type === 'Feature') features.push(g);
  };
  collect(geo);

  // Pre-pass: collect all rings to detect projection
  const allRings = [];
  features.forEach(f => {
    if (!f.geometry) return;
    if (f.geometry.type === 'Polygon') allRings.push(f.geometry.coordinates[0]);
    else if (f.geometry.type === 'MultiPolygon') f.geometry.coordinates.forEach(poly => allRings.push(poly[0]));
  });
  if (allRings.length === 0) { alert('Aucun polygone trouvé dans le fichier.'); return; }

  const detect = detectAndReproject(allRings);
  if (!detect.rings) {
    alert('Projection non reconnue : ' + detect.error + '\n\nLes systèmes pris en charge sont : WGS84 (lon/lat), Lambert-93 (EPSG:2154), Lambert II étendu (EPSG:27572), Web Mercator (EPSG:3857).');
    return;
  }

  // Build a map from old ring reference to reprojected ring (preserve mapping order)
  const reprojIter = detect.rings[Symbol.iterator]();

  const candidates = [];
  features.forEach(f => {
    if (!f.geometry) return;
    const props = f.properties || {};
    const guessName = props.NUM_ILOT || props.ID_ILOT || props.NUMERO_I || props.numero_il ||
                      props.ilot || props.ID || props.id ||
                      props.name || props.NAME || props.NOM || props.nom || '';
    const guessNote = [props.CULTURE, props.LIBELLE_C, props.libelle_c, props.libelle, props.commune, props.COMMUNE]
                       .filter(Boolean).join(' · ');
    if (f.geometry.type === 'Polygon') {
      const ring = reprojIter.next().value;
      candidates.push({ ring, name: guessName, note: guessNote, props });
    } else if (f.geometry.type === 'MultiPolygon') {
      f.geometry.coordinates.forEach((poly, i) => {
        const ring = reprojIter.next().value;
        candidates.push({
          ring,
          name: guessName ? `${guessName}-${i+1}` : '',
          note: guessNote, props,
        });
      });
    }
  });

  if (candidates.length === 0) { alert('Aucun polygone trouvé dans le fichier.'); return; }
  console.log('Import :', detect.projection);

  const label = isTelepac ? 'îlot(s) Télépac' : 'parcelle(s)';
  const ok = confirm(
    `${candidates.length} ${label} trouvé(s).\n\n` +
    `Confirmer l'AJOUT à vos ${state.parcelles.length} parcelle(s) existante(s) ?`
  );
  if (!ok) return;

  snapshotState(`Import de ${candidates.length} ${label}`);
  const baseStamp = Date.now();
  candidates.forEach((c, i) => {
    const ring = ensureClosed(c.ring.slice());
    state.parcelles.push({
      id: 'p_' + baseStamp + '_' + i + '_' + Math.random().toString(36).slice(2, 5),
      name: c.name ? String(c.name) : (isTelepac ? `Îlot ${i + 1}` : `Importée ${i + 1}`),
      note: c.note || '',
      usage: 'pature',
      coords: ring,
      surface: polygonAreaHa(ring),
      sejours: [],
      events: [],
      created: todayISO(),
      source: isTelepac ? 'telepac' : 'geojson',
    });
  });
  saveData();
  renderParcelles();
  const all = L.featureGroup();
  state.parcelles.forEach(p => all.addLayer(L.polygon(p.coords.map(c => [c[1], c[0]]))));
  if (all.getLayers().length) map.fitBounds(all.getBounds(), { padding: [40, 40] });
  closeModal();
  alert(`${candidates.length} ${label} importé(s).`);
}

window.resetAll = function() {
  if (!confirm('Tout effacer ? Cette action est irréversible. Pensez à exporter avant.')) return;
  if (!confirm('Vraiment ? Toutes les parcelles et l\'historique seront perdus.')) return;
  state = { parcelles: [], settings: { restDays: 30 } };
  saveData(); renderParcelles(); closeModal();
};


window.reprojectExisting = function() {
  // Collect all rings, attempt to detect & reproject
  const allRings = state.parcelles.map(p => p.coords);
  const detect = detectAndReproject(allRings);
  if (!detect.rings) {
    alert('Reprojection impossible : ' + detect.error);
    return;
  }
  if (detect.projection === 'WGS84 (lon/lat)') {
    alert('Les coordonnées sont déjà en WGS84, rien à faire.');
    return;
  }
  if (!confirm('Reprojeter ' + state.parcelles.length + ' parcelle(s) depuis ' + detect.projection + ' ?')) return;
  state.parcelles.forEach((p, i) => {
    p.coords = ensureClosed(detect.rings[i]);
    p.surface = polygonAreaHa(p.coords);
  });
  saveData();
  renderParcelles();
  const all = L.featureGroup();
  state.parcelles.forEach(p => all.addLayer(L.polygon(p.coords.map(c => [c[1], c[0]]))));

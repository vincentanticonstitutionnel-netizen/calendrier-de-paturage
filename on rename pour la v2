window.saveNewLot = function() {
  const name = document.getElementById('newLotName').value.trim();
  const color = document.getElementById('newLotColor').value;
  if (!name) return alert('Nom requis');
  if (state.lots.some(l => l.name.toLowerCase() === name.toLowerCase())) return alert('Ce nom existe déjà.');

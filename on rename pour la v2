window.addEvent = function(id) {
  const p = state.parcelles.find(x => x.id === id);
  if (!p) return;
  const typeOptions = Object.entries(EVENT_TYPES).map(([k, v]) =>
    `<option value="${k}" data-unit="${v.defaultUnit}">${v.icon} ${escapeHtml(v.label)}</option>`
  ).join('');
  openModal(`
    <h2>Nouvel événement</h2>
    <div class="info-card"><strong>${escapeHtml(p.name)}</strong> · ${p.surface.toFixed(2)} ha</div>
    <label>Type</label>
    <select id="evType" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:6px;font-size:16px;font-family:inherit;background:var(--bg);color:var(--ink);">
      ${typeOptions}
    </select>
    <label>Date</label>
    <input type="date" id="evDate" value="${todayISO()}">
    <label>Quantité (facultatif)</label>
    <div style="display:flex;gap:8px">
      <input type="text" id="evQty" inputmode="decimal" placeholder="ex: 4.2" style="flex:2">
      <input type="text" id="evUnit" placeholder="t" style="flex:1">
    </div>
    <div style="font-size:11px;color:var(--muted);margin-top:4px">Unités libres : t, kg, kg/ha, L/ha, balles, bottes…</div>
    <label>Note (facultatif)</label>
    <textarea id="evNote" rows="2" placeholder="ex: 1ère coupe, foin sec, vendu à X"></textarea>
    <div class="modal-actions">
      <button onclick="openParcelle('${p.id}')">Annuler</button>
      <button class="primary" onclick="saveEvent('${p.id}')">Enregistrer</button>
    </div>
  `);
  // Auto-fill unit when type changes
  const sel = document.getElementById('evType');
  const unitInput = document.getElementById('evUnit');
  const setDefaultUnit = () => {
    const opt = sel.options[sel.selectedIndex];
    if (opt && !unitInput.value) unitInput.value = opt.getAttribute('data-unit') || '';
  };
  sel.addEventListener('change', () => { unitInput.value = sel.options[sel.selectedIndex].getAttribute('data-unit') || ''; });
  setDefaultUnit();
};

window.saveEvent = function(id) {
  const p = state.parcelles.find(x => x.id === id);
  if (!p) return;
  const type = document.getElementById('evType').value;
  const date = document.getElementById('evDate').value;
  const qtyRaw = document.getElementById('evQty').value.trim().replace(',', '.');
  const unit = document.getElementById('evUnit').value.trim();
  const note = document.getElementById('evNote').value.trim();
  if (!date) return alert('Date requise');
  const qty = qtyRaw === '' ? null : parseFloat(qtyRaw);
  if (qtyRaw !== '' && isNaN(qty)) return alert('Quantité invalide');
  if (!Array.isArray(p.events)) p.events = [];
  snapshotState(`Événement ${eventTypeLabel(type)} sur « ${p.name} »`);
  p.events.push({
    id: 'ev_' + Date.now() + '_' + Math.random().toString(36).slice(2, 5),
    type, date, qty, unit, note,
  });
  saveData();
  closeModal();
};

window.deleteEvent = function(parcelId, eventId) {
  if (!confirm('Supprimer cet événement ?')) return;
  const p = state.parcelles.find(x => x.id === parcelId);
  if (!p) return;
  p.events = (p.events || []).filter(e => e.id !== eventId);
  saveData();
  openParcelle(parcelId);
};

window.deleteParcelle = function(id) {
  const p = state.parcelles.find(x => x.id === id);
  if (!p) return;
  if (!confirm('Supprimer cette parcelle et tout son historique ?')) return;
  snapshotState(`Suppression de « ${p.name} »`);
  state.parcelles = state.parcelles.filter(p => p.id !== id);
  saveData(); renderParcelles(); closeModal();
};


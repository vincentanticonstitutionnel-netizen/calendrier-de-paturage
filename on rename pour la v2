// ============== UNDO HISTORY ==============
const UNDO_LIMIT = 20;
let undoStack = []; // each entry: { description, parcelles: deep clone }
let selectedParcelId = null; // currently highlighted parcelle (1st tap)

function snapshotState(description) {
  // Deep clone parcelles so the snapshot is independent
  const clone = JSON.parse(JSON.stringify(state.parcelles));
  undoStack.push({ description, parcelles: clone });
  if (undoStack.length > UNDO_LIMIT) undoStack.shift();
  refreshUndoButton();
}

function refreshUndoButton() {
  const btns = [document.getElementById('btnUndo'), document.getElementById('btnUndoUsage')];
  btns.forEach(btn => {
    if (!btn) return;
    if (undoStack.length === 0) {
      btn.disabled = true;
      btn.style.opacity = '0.4';
      btn.title = 'Rien à annuler';
    } else {
      btn.disabled = false;
      btn.style.opacity = '1';
      const last = undoStack[undoStack.length - 1];
      btn.title = 'Annuler : ' + last.description;
    }
  });
}

function performUndo() {
  if (undoStack.length === 0) return;
  const last = undoStack.pop();
  if (!confirm(`Annuler : « ${last.description} » ?`)) {
    undoStack.push(last); // restore
    return;
  }
  state.parcelles = last.parcelles;
  saveData();
  renderParcelles();
  closeModal();
  // Clear selection too in case
  selectedParcelId = null;
  refreshUndoButton();
}
const banner = document.getElementById('modeBanner');
const editToolbar = document.getElementById('editToolbar');

function setMode(m) {
  mode = m;
  if (m === 'idle') {
    banner.classList.remove('show', 'edit');
    editToolbar.classList.remove('show');
  } else {
    editToolbar.classList.add('show');
  }
}
function showBanner(msg, isEdit) {
  banner.textContent = msg;
  banner.classList.add('show');
  banner.classList.toggle('edit', !!isEdit);
}

// ============== DRAW MODE ==============
let drawPoints = [], drawMarkers = [], drawPolyline = null, drawClickHandler = null;

function startDraw() {
  if (mode !== 'idle') return;
  setMode('drawing');
  drawPoints = []; drawMarkers = [];
  drawPolyline = L.polyline([], { color: getCSS('--accent'), weight: 2, dashArray: '5,5' }).addTo(map);
  showBanner('Touchez la carte pour ajouter des points. Tap sur un point existant pour le supprimer. ✓ pour terminer.', true);
  drawClickHandler = (e) => {
    const snapped = snapPoint([e.latlng.lng, e.latlng.lat], null);
    addDrawPoint(snapped);
    setTimeout(hideSnapIndicator, 600);
  };
  map.on('click', drawClickHandler);
}

function addDrawPoint(pt) {
  drawPoints.push(pt);
  rebuildDrawMarkers();
}

function rebuildDrawMarkers() {
  drawMarkers.forEach(m => map.removeLayer(m));
  drawMarkers = [];
  drawPoints.forEach((pt, i) => {
    const marker = L.marker([pt[1], pt[0]], {
      icon: L.divIcon({
        className: '',
        html: `<div class="vertex-handle" style="width:20px;height:20px;margin-left:-10px;margin-top:-10px;"></div>`,
        iconSize: [0, 0],
      }),
      draggable: true,
    }).addTo(map);
    let dragged = false;
    marker.on('dragstart', () => { dragged = false; });
    marker.on('drag', (e) => {
      dragged = true;
      const ll = e.target.getLatLng();
      drawPoints[i] = [ll.lng, ll.lat];
      redrawDrawLine();
    });
    marker.on('dragend', (e) => {
      const ll = e.target.getLatLng();
      const snapped = snapPoint([ll.lng, ll.lat], null);
      drawPoints[i] = snapped;
      e.target.setLatLng([snapped[1], snapped[0]]);
      redrawDrawLine();
      setTimeout(hideSnapIndicator, 600);
    });
    marker.on('click', (e) => {
      L.DomEvent.stopPropagation(e);
      if (dragged) return;
      drawPoints.splice(i, 1);
      rebuildDrawMarkers();
    });
    drawMarkers.push(marker);
  });
  redrawDrawLine();
}

function redrawDrawLine() {
  if (!drawPolyline) return;
  const closed = drawPoints.length >= 3 ? drawPoints.concat([drawPoints[0]]) : drawPoints;
  drawPolyline.setLatLngs(closed.map(p => [p[1], p[0]]));
}

function undoDrawPoint() {
  if (mode !== 'drawing' || drawPoints.length === 0) return;
  drawPoints.pop();
  rebuildDrawMarkers();
}

function finishDraw() {
  if (mode !== 'drawing') return;
  if (drawPoints.length < 3) { alert('Au moins 3 points sont nécessaires.'); return; }
  const ring = ensureClosed(drawPoints.slice());
  cleanupDraw();
  promptNewParcelle(ring);
}
function cancelDraw() { cleanupDraw(); }
function cleanupDraw() {
  if (drawClickHandler) { map.off('click', drawClickHandler); drawClickHandler = null; }
  drawMarkers.forEach(m => map.removeLayer(m));
  drawMarkers = [];
  if (drawPolyline) { map.removeLayer(drawPolyline); drawPolyline = null; }
  drawPoints = [];
  hideSnapIndicator();
  setMode('idle');
}

// ============== EDIT MODE ==============
let editParcelId = null, editPoints = [], editPolygon = null;
let editVertexMarkers = [], editMidMarkers = [];

function startEdit(parcelId) {
  if (mode !== 'idle') return;
  closeModal();
  const p = state.parcelles.find(x => x.id === parcelId);
  if (!p) return;
  editParcelId = parcelId;
  editPoints = unclose(p.coords.map(c => c.slice()));
  setMode('editing');
  showBanner('Glissez les points bleus. Tap pour supprimer. Tap sur un point clair pour insérer.', true);
  editPolygon = L.polygon(editPoints.map(c => [c[1], c[0]]), {
    color: getCSS('--edit'), weight: 2, fillColor: getCSS('--edit'), fillOpacity: 0.15,
  }).addTo(map);
  rebuildEditHandles();
  document.getElementById('etUndo').style.display = 'none';
}

function rebuildEditHandles() {
  editVertexMarkers.forEach(m => map.removeLayer(m));
  editMidMarkers.forEach(m => map.removeLayer(m));
  editVertexMarkers = []; editMidMarkers = [];

  editPoints.forEach((pt, idx) => {
    const m = L.marker([pt[1], pt[0]], {
      icon: L.divIcon({
        className: '',
        html: `<div class="vertex-handle" style="width:22px;height:22px;margin-left:-11px;margin-top:-11px;"></div>`,
        iconSize: [0, 0],
      }),
      draggable: true,
    }).addTo(map);
    let dragged = false;
    m.on('dragstart', () => { dragged = false; });
    m.on('drag', (e) => {
      dragged = true;
      const ll = e.target.getLatLng();
      editPoints[idx] = [ll.lng, ll.lat];
      updateEditPolygon();
    });
    m.on('dragend', (e) => {
      const ll = e.target.getLatLng();
      const snapped = snapPoint([ll.lng, ll.lat], editParcelId);
      editPoints[idx] = snapped;
      e.target.setLatLng([snapped[1], snapped[0]]);
      updateEditPolygon();
      buildMidpoints();
      setTimeout(hideSnapIndicator, 600);
    });
    m.on('click', (e) => {
      L.DomEvent.stopPropagation(e);
      if (dragged) return;
      if (editPoints.length <= 3) { alert('Minimum 3 points.'); return; }
      editPoints.splice(idx, 1);
      updateEditPolygon();
      rebuildEditHandles();
    });
    editVertexMarkers.push(m);
  });
  buildMidpoints();
  updateEditPolygon();
}

function buildMidpoints() {
  editMidMarkers.forEach(m => map.removeLayer(m));
  editMidMarkers = [];
  for (let i = 0; i < editPoints.length; i++) {
    const a = editPoints[i];
    const b = editPoints[(i + 1) % editPoints.length];
    const mid = [(a[0] + b[0]) / 2, (a[1] + b[1]) / 2];
    const insertAt = i + 1;
    const m = L.marker([mid[1], mid[0]], {
      icon: L.divIcon({
        className: '',
        html: `<div class="vertex-midpoint" style="width:16px;height:16px;margin-left:-8px;margin-top:-8px;"></div>`,
        iconSize: [0, 0],
      }),
      interactive: true,
    }).addTo(map);
    m.on('click', (e) => {
      L.DomEvent.stopPropagation(e);
      editPoints.splice(insertAt, 0, mid);
      rebuildEditHandles();
    });
    editMidMarkers.push(m);
  }
}

function updateEditPolygon() {
  if (editPolygon) editPolygon.setLatLngs(editPoints.map(c => [c[1], c[0]]));
}

function finishEdit() {
  if (mode !== 'editing') return;
  if (editPoints.length < 3) { alert('Minimum 3 points.'); return; }
  const p = state.parcelles.find(x => x.id === editParcelId);
  if (p) {
    snapshotState(`Modification du tracé de « ${p.name} »`);
    p.coords = ensureClosed(editPoints.slice());
    p.surface = polygonAreaHa(p.coords);
    saveData();
    renderParcelles();
  }
  cleanupEdit();
}
function cancelEdit() { cleanupEdit(); }
function cleanupEdit() {
  editVertexMarkers.forEach(m => map.removeLayer(m));
  editMidMarkers.forEach(m => map.removeLayer(m));
  if (editPolygon) map.removeLayer(editPolygon);
  editVertexMarkers = []; editMidMarkers = [];
  editPolygon = null; editPoints = []; editParcelId = null;
  document.getElementById('etUndo').style.display = '';
  hideSnapIndicator();
  setMode('idle');
}

// ============== MERGE MODE ==============
function startMergeSelection() {
  closeModal();
  if (state.parcelles.length < 2) {
    alert('Au moins 2 parcelles sont nécessaires pour fusionner.');
    return;
  }
  mergeSelectActive = true;
  mergeSelection = [];
  setMode('merging');
  showBanner('Touchez 2 parcelles ou plus à fusionner. Re-tap pour désélectionner.', true);
  document.getElementById('etUndo').style.display = 'none';
  renderParcelles();
}

function toggleMergeSelection(parcelId) {
  const idx = mergeSelection.indexOf(parcelId);
  if (idx >= 0) mergeSelection.splice(idx, 1);
  else mergeSelection.push(parcelId);
  renderParcelles();
  const n = mergeSelection.length;
  showBanner(`${n} parcelle(s) sélectionnée(s). ✓ pour fusionner (min. 2).`, true);
}

function finishMerge() {
  if (mergeSelection.length < 2) { alert('Sélectionnez au moins 2 parcelles.'); return; }
  const selected = mergeSelection.map(id => state.parcelles.find(p => p.id === id)).filter(Boolean);
  // Compute geometric union via polyclip-ts (or fallback to polygon-clipping)
  // Lib expects [[ring, hole, ...], ...] (MultiPolygon-like)
  const inputs = selected.map(p => [p.coords]);
  const lib = (typeof polyclip !== 'undefined') ? polyclip
            : (typeof polygonClipping !== 'undefined') ? polygonClipping
            : (typeof window['polygon-clipping'] !== 'undefined') ? window['polygon-clipping']
            : null;
  if (!lib) {
    alert('Bibliothèque de fusion non chargée. Vérifiez la connexion internet pour cette première utilisation, puis réessayez.');
    return;
  }
  let union;
  try {
    union = lib.union(...inputs);
  } catch (err) {
    alert('Erreur de calcul de l\'union : ' + err.message);
    return;
  }
  if (!union || union.length === 0) { alert('Fusion impossible.'); return; }
  if (union.length > 1) {
    if (!confirm(`Les parcelles sélectionnées ne sont pas toutes adjacentes (${union.length} groupes distincts détectés). La fusion va les regrouper en une seule entité avec plusieurs morceaux. Continuer ?`)) return;
  }
  // For our model (single polygon per parcelle), if union has >1 polygons we keep the largest only;
  // for adjacent parcelles, union will return a single polygon, which is the normal case.
  let chosen = union[0];
  if (union.length > 1) {
    // pick the largest by area
    let bestArea = 0;
    union.forEach(poly => {
      const a = polygonAreaHa(poly[0]);
      if (a > bestArea) { bestArea = a; chosen = poly; }
    });
  }
  const outerRing = chosen[0]; // outer ring (we ignore holes for our use case)

  // Pick which parcelle keeps its identity: the largest one
  let keeper = selected[0];
  selected.forEach(p => { if (p.surface > keeper.surface) keeper = p; });

  // Show merge confirmation
  const nameOptions = selected.map(p =>
    `<option value="${p.id}" ${p.id === keeper.id ? 'selected' : ''}>${escapeHtml(p.name)} (${p.surface.toFixed(2)} ha)</option>`
  ).join('');

  openModal(`

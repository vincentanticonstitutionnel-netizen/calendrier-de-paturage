<script>
'use strict';

// =====================================================
// CONFIGURATION SUPABASE
// =====================================================
const SUPABASE_URL = 'https://rizodpcstivvaalmggpk.supabase.co';
const SUPABASE_ANON_KEY = 'sb_publishable_awZGoVUSCgDh6O98NEL4aQ_9o0wJ-v7';
  const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY, {
  auth: { persistSession: true, autoRefreshToken: true }
});

// État de synchronisation
let currentUser = null;
let syncStatus = 'offline'; // 'synced' | 'pending' | 'syncing' | 'offline' | 'error'
let pendingPush = false;
let pushTimer = null;
let lastServerUpdatedAt = null;
// =====================================================

const STORAGE_KEY = 'paturage_v1';
// Schema:
// parcelle.usage: 'pature' | 'foin' | 'mixte' | 'culture' | 'autre' (default 'pature')
// parcelle.events: [{ id, date, type, qty, unit, note }]
//   type: 'fauche' | 'regain' | 'ensilage' | 'fumure' | 'semis' | 'traitement' | 'recolte' | 'autre'

// Snapping (declared early so loadData() can read persisted setting)
let snapEnabled = true;

function loadData() {
  try {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return defaultState();
    const d = JSON.parse(raw);
    if (!d.parcelles) d.parcelles = [];
    if (!d.settings) d.settings = { restDays: 30 };
    // Migration: ensure usage and events fields
    d.parcelles.forEach(p => {
      if (!p.usage) p.usage = 'pature';
      if (!Array.isArray(p.events)) p.events = [];
    });
    // Migration: ensure lots
    if (!Array.isArray(d.lots) || d.lots.length === 0) {
      d.lots = [{ id: 'lot_default', name: 'Troupeau', color: '#b8541a' }];
    }
    // Migration: assign default lot to existing sejours
    const defaultLotId = d.lots[0].id;
    d.parcelles.forEach(p => {
      (p.sejours || []).forEach(s => {
        if (!s.lotId) s.lotId = defaultLotId;
      });
    });
    if (typeof d.settings.snapEnabled === 'boolean') {
      snapEnabled = d.settings.snapEnabled;
    }
    return d;
  } catch (e) { return defaultState(); }
}
function defaultState() {
  return {
    parcelles: [],
    settings: { restDays: 30 },
    lots: [{ id: 'lot_default', name: 'Troupeau', color: '#b8541a' }],
  };
}
function saveData() {
  // Toujours sauvegarder en local d'abord (rapide, fonctionne hors ligne)
  state.updated_at = new Date().toISOString();
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  // Puis programmer une synchro vers le serveur (debounced)
  schedulePush();
}

// =====================================================
// SYNCHRONISATION SUPABASE
// =====================================================

function setSyncStatus(s) {
  syncStatus = s;
  updateSyncIndicator();
}

function updateSyncIndicator() {
  const el = document.getElementById('syncIndicator');
  if (!el) return;
  const labels = {
    synced: '🟢 Synchronisé',
    pending: '🟡 En attente',
    syncing: '🟡 Synchro...',
    offline: '🔴 Hors ligne',
    error: '⚠️ Erreur'
  };
  el.textContent = labels[syncStatus] || '';
  el.title = {
    synced: 'Toutes les modifications sont sauvegardées sur le serveur',
    pending: 'Modifications locales en attente de synchronisation',
    syncing: 'Synchronisation en cours...',
    offline: 'Hors ligne - les modifications seront synchronisées au retour du réseau',
    error: 'Erreur de synchronisation - vos données sont sauvegardées localement'
  }[syncStatus] || '';
}

function schedulePush() {
  if (!currentUser) return; // pas connecté = pas de push
  pendingPush = true;
  if (syncStatus !== 'syncing') setSyncStatus('pending');
  // Debounce : on attend 1.5s sans nouvelle modif avant de pousser
  if (pushTimer) clearTimeout(pushTimer);
  pushTimer = setTimeout(() => { pushToServer(); }, 1500);
}

async function pushToServer() {
  if (!currentUser || !pendingPush) return;
  if (!navigator.onLine) {
    setSyncStatus('offline');
    return;
  }
  setSyncStatus('syncing');
  try {
    const payload = {
      user_id: currentUser.id,
      data: state,
      updated_at: new Date().toISOString()
    };
    const { error } = await sb
      .from('user_data')
      .upsert(payload, { onConflict: 'user_id' });
    if (error) throw error;
    pendingPush = false;
    lastServerUpdatedAt = payload.updated_at;
    setSyncStatus('synced');
  } catch (e) {
    console.error('[sync] push failed:', e);
    setSyncStatus(navigator.onLine ? 'error' : 'offline');
    // Retry dans 30s
    setTimeout(() => { if (pendingPush) pushToServer(); }, 30000);
  }
}

async function pullFromServer() {
  if (!currentUser) return null;
  try {
    const { data, error } = await sb
      .from('user_data')
      .select('data, updated_at')
      .eq('user_id', currentUser.id)
      .maybeSingle();
    if (error) throw error;
    return data; // { data, updated_at } ou null si pas de ligne
  } catch (e) {
    console.error('[sync] pull failed:', e);
    return null;
  }
}

// Au login : récupère les données serveur et choisit la version la plus récente
async function syncOnLogin() {
  setSyncStatus('syncing');
  const server = await pullFromServer();
  const localRaw = localStorage.getItem(STORAGE_KEY);
  const localState = localRaw ? JSON.parse(localRaw) : null;
  const localUpdated = localState && localState.updated_at ? localState.updated_at : null;

  // Cas 1 : rien sur le serveur
  if (!server) {
    if (localState && localState.parcelles && localState.parcelles.length > 0) {
      // L'utilisateur avait des données locales : on propose de les pousser
      const ok = confirm(
        `Vous avez ${localState.parcelles.length} parcelle(s) en local sur cet appareil.\n\n` +
        `Voulez-vous les associer à votre compte et les synchroniser ?\n\n` +
        `(Annuler = repartir de zéro avec un compte vide)`
      );
      if (ok) {
        state = localState;
        pendingPush = true;
        await pushToServer();
        return;
      } else {
        state = defaultState();
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
        renderParcelles();
        setSyncStatus('synced');
        return;
      }
    } else {
      // Pas de local non plus : tout vide, on initialise
      state = defaultState();
      setSyncStatus('synced');
      return;
    }
  }

  // Cas 2 : il y a des données serveur
  const serverUpdated = server.updated_at;
  lastServerUpdatedAt = serverUpdated;

  // Si pas de local OU local plus ancien : on prend le serveur
  if (!localUpdated || new Date(serverUpdated) >= new Date(localUpdated)) {
    state = server.data;
    if (!state.parcelles) state.parcelles = [];
    if (!state.lots || state.lots.length === 0) {
      state.lots = [{ id: 'lot_default', name: 'Troupeau', color: '#b8541a' }];
    }
    if (!state.settings) state.settings = { restDays: 30 };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    renderParcelles();
    setSyncStatus('synced');
    return;
  }

  // Si local plus récent : on pousse vers le serveur
  state = localState;
  pendingPush = true;
  await pushToServer();
  renderParcelles();
}


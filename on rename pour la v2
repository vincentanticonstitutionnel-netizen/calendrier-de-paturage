let splitParcelId = null, splitLinePoints = [], splitMarkers = [];
let splitPolyline = null, splitClickHandler = null, splitHighlight = null;

function startSplit(parcelIdOpt) {
  if (mode !== 'idle') return;
  closeModal();
  setMode('splitting');
  if (parcelIdOpt) {
    splitParcelId = parcelIdOpt;
    highlightSplitParcel();
    beginSplitLine();
  } else {
    showBanner('Sélectionnez la parcelle à découper.', true);
    parcelLayer.eachLayer(layer => {
      const h = (e) => {
        L.DomEvent.stopPropagation(e);
        splitParcelId = layer.parcelId;
        parcelLayer.eachLayer(l => { if (l._splitHandler) { l.off('click', l._splitHandler); delete l._splitHandler; } });
        highlightSplitParcel();
        beginSplitLine();
      };
      layer._splitHandler = h;
      layer.on('click', h);
    });
  }
}

function highlightSplitParcel() {
  const p = state.parcelles.find(x => x.id === splitParcelId);
  if (!p) return;
  splitHighlight = L.polygon(p.coords.map(c => [c[1], c[0]]), {
    color: '#ff3333', weight: 4, fillOpacity: 0,
  }).addTo(map);
}

function beginSplitLine() {
  splitLinePoints = []; splitMarkers = [];
  splitPolyline = L.polyline([], { color: '#ff3333', weight: 5, dashArray: '8,4' }).addTo(map);
  showBanner('Tracez une ligne traversant la parcelle (entrée et sortie). ✓ pour découper.', true);
  splitClickHandler = (e) => addSplitPoint([e.latlng.lng, e.latlng.lat]);
  map.on('click', splitClickHandler);
}

function addSplitPoint(pt) {
  splitLinePoints.push(pt);
  rebuildSplitMarkers();
}

function rebuildSplitMarkers() {
  splitMarkers.forEach(m => map.removeLayer(m));
  splitMarkers = [];
  splitLinePoints.forEach((pt, i) => {
    const marker = L.marker([pt[1], pt[0]], {
      icon: L.divIcon({
        className: '',
        html: `<div class="vertex-handle" style="width:22px;height:22px;margin-left:-11px;margin-top:-11px;background:#ff3333;"></div>`,
        iconSize: [0, 0],
      }),
      draggable: true,
    }).addTo(map);
    let dragged = false;
    marker.on('dragstart', () => { dragged = false; });
    marker.on('drag', (e) => {
      dragged = true;
      const ll = e.target.getLatLng();
      splitLinePoints[i] = [ll.lng, ll.lat];
      splitPolyline.setLatLngs(splitLinePoints.map(p => [p[1], p[0]]));
    });
    marker.on('click', (e) => {
      L.DomEvent.stopPropagation(e);
      if (dragged) return;
      splitLinePoints.splice(i, 1);
      rebuildSplitMarkers();
    });
    splitMarkers.push(marker);
  });
  splitPolyline.setLatLngs(splitLinePoints.map(p => [p[1], p[0]]));
}

function undoSplitPoint() {
  if (mode !== 'splitting' || splitLinePoints.length === 0) return;
  splitLinePoints.pop();
  rebuildSplitMarkers();
}

function finishSplit() {
  if (mode !== 'splitting') return;
  if (!splitParcelId) { alert('Sélectionnez d\'abord une parcelle.'); return; }
  if (splitLinePoints.length < 2) { alert('Tracez une ligne d\'au moins 2 points.'); return; }
  const p = state.parcelles.find(x => x.id === splitParcelId);
  if (!p) { cleanupSplit(); return; }

  const result = splitPolygonByLine(unclose(p.coords.slice()), splitLinePoints);
  if (!result || result.length < 2) {
    alert('La ligne doit traverser entièrement la parcelle (entrée d\'un côté, sortie de l\'autre).');
    return;
  }

  const baseName = p.name;
  snapshotState(`Découpage de « ${baseName} »`);
  const newParcels = result.map((ring, i) => ({
    id: newId(),
    name: `${baseName}-${String.fromCharCode(65 + i)}`,
    note: p.note || '',
    usage: p.usage || 'pature',
    coords: ensureClosed(ring),
    surface: polygonAreaHa(ensureClosed(ring)),
    sejours: [],
    events: [],
    parent: p.id,
    created: todayISO(),
  }));
  state.parcelles = state.parcelles.filter(x => x.id !== splitParcelId);
  state.parcelles.push(...newParcels);
  saveData();
  renderParcelles();
  cleanupSplit();

  openModal(`
    <h2>Découpage effectué</h2>
    <div class="info-card">
      « ${escapeHtml(baseName)} » a été découpée en <strong>${newParcels.length}</strong> parcelles :<br>
      ${newParcels.map(np => `• ${escapeHtml(np.name)} — ${np.surface.toFixed(2)} ha`).join('<br>')}
    </div>
    <p style="font-size:13px;color:var(--muted)">Touchez chaque parcelle puis « Renommer » si besoin.</p>
    <div class="modal-actions"><button class="primary" onclick="closeModal()">OK</button></div>
  `);
}

function cancelSplit() { cleanupSplit(); }
function cleanupSplit() {
  if (splitClickHandler) { map.off('click', splitClickHandler); splitClickHandler = null; }
  parcelLayer.eachLayer(layer => {
    if (layer._splitHandler) { layer.off('click', layer._splitHandler); delete layer._splitHandler; }
  });
  splitMarkers.forEach(m => map.removeLayer(m));
  splitMarkers = [];
  if (splitPolyline) { map.removeLayer(splitPolyline); splitPolyline = null; }
  if (splitHighlight) { map.removeLayer(splitHighlight); splitHighlight = null; }
  splitLinePoints = []; splitParcelId = null;
  setMode('idle');
}

// ============== POLYGON SPLITTING ==============
function splitPolygonByLine(ringUnclosed, line) {
  const ring = ringUnclosed;
  const n = ring.length;
  if (n < 3 || line.length < 2) return null;

  const polyEdges = [];
  for (let i = 0; i < n; i++) polyEdges.push([ring[i], ring[(i + 1) % n]]);

  const intersections = [];
  for (let li = 0; li < line.length - 1; li++) {
    const a = line[li], b = line[li + 1];
    for (let ei = 0; ei < polyEdges.length; ei++) {
      const c = polyEdges[ei][0], d = polyEdges[ei][1];
      const inter = segIntersect(a, b, c, d);
      if (inter) {
        intersections.push({
          edgeIdx: ei, point: inter.point,
          tEdge: inter.tCD, tLine: li + inter.tAB,
        });
      }
    }
  }
  if (intersections.length < 2) return null;
  intersections.sort((a, b) => a.tLine - b.tLine);
  const first = intersections[0];
  const last = intersections[intersections.length - 1];
  if (first.edgeIdx === last.edgeIdx && Math.abs(first.tEdge - last.tEdge) < 1e-9) return null;

  const augmented = [];
  const insertions = {};
  function pushIns(it) {
    if (!insertions[it.edgeIdx]) insertions[it.edgeIdx] = [];
    insertions[it.edgeIdx].push(it);
  }
  pushIns(first); pushIns(last);
  for (const k in insertions) insertions[k].sort((a, b) => a.tEdge - b.tEdge);

  let firstIdx = -1, lastIdx = -1;
  for (let i = 0; i < n; i++) {
    augmented.push({ pt: ring[i], cut: null });
    if (insertions[i]) {
      for (const it of insertions[i]) {
        const tag = (it === first) ? 'first' : (it === last) ? 'last' : null;
        const idx = augmented.length;
        augmented.push({ pt: it.point, cut: tag });
        if (tag === 'first') firstIdx = idx;
        else if (tag === 'last') lastIdx = idx;
      }
    }
  }
  if (firstIdx < 0 || lastIdx < 0) return null;

  const midLinePoints = [];
  for (let li = 0; li < line.length; li++) {
    if (li > first.tLine && li < last.tLine) midLinePoints.push(line[li]);
  }

  const N = augmented.length;
  const pieceA = [];
  let i = firstIdx;
  while (true) {
    pieceA.push(augmented[i].pt);
    if (i === lastIdx) break;
    i = (i + 1) % N;
  }
  for (let k = midLinePoints.length - 1; k >= 0; k--) pieceA.push(midLinePoints[k]);

  const pieceB = [];
  i = lastIdx;
  while (true) {
    pieceB.push(augmented[i].pt);
    if (i === firstIdx) break;
    i = (i + 1) % N;
  }
  for (let k = 0; k < midLinePoints.length; k++) pieceB.push(midLinePoints[k]);

  if (pieceA.length < 3 || pieceB.length < 3) return null;
  return [pieceA, pieceB];
}

function segIntersect(a, b, c, d) {
  const x1 = a[0], y1 = a[1], x2 = b[0], y2 = b[1];
  const x3 = c[0], y3 = c[1], x4 = d[0], y4 = d[1];
  const denom = (x1 - x2) * (y3 - y4) - (y1 - y2) * (x3 - x4);
  if (Math.abs(denom) < 1e-15) return null;
  const tAB = ((x1 - x3) * (y3 - y4) - (y1 - y3) * (x3 - x4)) / denom;
  const tCD = -((x1 - x2) * (y1 - y3) - (y1 - y2) * (x1 - x3)) / denom;
  if (tAB < -1e-9 || tAB > 1 + 1e-9) return null;
  if (tCD < -1e-9 || tCD > 1 + 1e-9) return null;
  return {
    point: [x1 + tAB * (x2 - x1), y1 + tAB * (y2 - y1)],
    tAB: Math.max(0, Math.min(1, tAB)),
    tCD: Math.max(0, Math.min(1, tCD)),
  };
}


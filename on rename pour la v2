function getLot(lotId) {
  return state.lots.find(l => l.id === lotId) || state.lots[0];
}
function lotColor(lotId) {
  const l = getLot(lotId);
  return l ? l.color : getCSS('--grazing');
}
// Find the parcelle currently occupied by a given lot, if any
function currentParcelForLot(lotId) {
  for (const p of state.parcelles) {
    const last = (p.sejours || [])[p.sejours.length - 1];
    if (last && !last.exit && last.lotId === lotId) return { parcelle: p, sejour: last };
  }
  return null;
}

function annualSummary(events) {
  // returns { '2025': { fauche: { total: 4.2, unit: 't', count: 2 }, ... }, ... }
  const out = {};
  events.forEach(ev => {
    const year = (ev.date || '').slice(0, 4);
    if (!year) return;
    if (!out[year]) out[year] = {};
    if (!out[year][ev.type]) out[year][ev.type] = { total: 0, unit: ev.unit || '', count: 0, mixed: false };
    const slot = out[year][ev.type];
    if (slot.unit && ev.unit && slot.unit !== ev.unit) slot.mixed = true;
    if (typeof ev.qty === 'number' && !isNaN(ev.qty)) slot.total += ev.qty;
    if (!slot.unit && ev.unit) slot.unit = ev.unit;
    slot.count += 1;
  });
  return out;
}

window.openParcelle = function(id) {

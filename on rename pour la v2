// ============== SNAPPING ==============
const SNAP_PIXELS = 20;
let snapIndicator = null;

function showSnapIndicator(latlng) {
  if (snapIndicator) map.removeLayer(snapIndicator);
  snapIndicator = L.circleMarker(latlng, {
    radius: 12, color: '#ff8800', fillColor: '#ff8800',
    fillOpacity: 0.2, weight: 2, interactive: false,
  }).addTo(map);
}
function hideSnapIndicator() {
  if (snapIndicator) { map.removeLayer(snapIndicator); snapIndicator = null; }
}

// Project a [lng,lat] to layer pixels
function toPixel(lnglat) {
  return map.latLngToLayerPoint(L.latLng(lnglat[1], lnglat[0]));
}
function fromPixel(pt) {
  const ll = map.layerPointToLatLng(pt);
  return [ll.lng, ll.lat];
}

// Distance from point P to segment AB in pixel space ; returns { dist, projection }
function pointSegPixelDist(p, a, b) {
  const dx = b.x - a.x, dy = b.y - a.y;
  const len2 = dx*dx + dy*dy;
  let t = len2 ? ((p.x - a.x) * dx + (p.y - a.y) * dy) / len2 : 0;
  t = Math.max(0, Math.min(1, t));
  const proj = L.point(a.x + t * dx, a.y + t * dy);
  return { dist: Math.hypot(p.x - proj.x, p.y - proj.y), projection: proj, t };
}

// Snap a [lng,lat] candidate to existing parcelle vertices/edges if within tolerance.
// excludeId: parcelle id to ignore (used during edit mode to avoid snapping to self).
// Returns either the original point or a snapped one.
function snapPoint(pt, excludeId) {
  if (!snapEnabled) { hideSnapIndicator(); return pt; }
  const pPix = toPixel(pt);
  let bestVertex = null, bestVertexDist = SNAP_PIXELS + 1;
  let bestEdge = null, bestEdgeDist = SNAP_PIXELS + 1;
  state.parcelles.forEach(par => {
    if (par.id === excludeId) return;
    const ring = par.coords;
    // vertices
    for (let i = 0; i < ring.length - 1; i++) { // -1 because last=first
      const v = ring[i];
      const vPix = toPixel(v);
      const d = Math.hypot(pPix.x - vPix.x, pPix.y - vPix.y);
      if (d < bestVertexDist) { bestVertexDist = d; bestVertex = v; }
    }
    // edges
    for (let i = 0; i < ring.length - 1; i++) {
      const a = ring[i], b = ring[(i + 1) % ring.length];
      const aPix = toPixel(a), bPix = toPixel(b);
      const r = pointSegPixelDist(pPix, aPix, bPix);
      if (r.dist < bestEdgeDist) {
        bestEdgeDist = r.dist;
        const ll = fromPixel(r.projection);
        bestEdge = ll;
      }
    }
  });
  // Vertex snap takes priority if both within tolerance
  if (bestVertex && bestVertexDist <= SNAP_PIXELS) {
    showSnapIndicator(L.latLng(bestVertex[1], bestVertex[0]));
    return [bestVertex[0], bestVertex[1]];
  }
  if (bestEdge && bestEdgeDist <= SNAP_PIXELS) {
    showSnapIndicator(L.latLng(bestEdge[1], bestEdge[0]));
    return bestEdge;
  }
  hideSnapIndicator();
  return pt;
}

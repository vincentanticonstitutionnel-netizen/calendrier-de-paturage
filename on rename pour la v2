window.exportXLSX = function() {
  if (state.parcelles.length === 0) {
    alert('Aucune parcelle à exporter.');
    return;
  }
  if (typeof XLSX === 'undefined') {
    alert('Bibliothèque Excel non chargée. Vérifiez votre connexion internet et réessayez.');
    return;
  }

  // Color palette per usage (light fill + dark text, matching the mockup)
  const USAGE_COLORS = {
    pature:  { fill: 'EAF3DE', text: '173404', accent: '97C459', label: 'Pâture' },
    foin:    { fill: 'FAEEDA', text: '412402', accent: 'EF9F27', label: 'Foin' },
    mixte:   { fill: 'EEEDFE', text: '26215C', accent: 'AFA9EC', label: 'Mixte' },
    culture: { fill: 'E6F1FB', text: '042C53', accent: '85B7EB', label: 'Culture' },
    autre:   { fill: 'F1EFE8', text: '2C2C2A', accent: 'B4B2A9', label: 'Autre' },
  };
  const USAGE_ORDER = ['pature', 'foin', 'mixte', 'culture', 'autre'];

  function thinBorder(rgb) {
    return {
      top: { style: 'thin', color: { rgb } },
      bottom: { style: 'thin', color: { rgb } },
      left: { style: 'thin', color: { rgb } },
      right: { style: 'thin', color: { rgb } },
    };
  }

  // Build event log per parcelle
  // sejour -> 1 row with both entry and exit dates
  // event -> 1 row
  function buildLog(p) {
    const log = [];
    (p.sejours || []).forEach(s => {
      const lotName = s.lotId ? (getLot(s.lotId)?.name || '') : '';
      const dur = s.exit ? daysBetween(s.entry, s.exit) : daysBetween(s.entry, todayISO());
      log.push({
        type: 'Pâturage',
        entryDate: s.entry,
        exitDate: s.exit || '',
        duration: dur,
        durationStr: s.exit ? String(dur) : `${dur} (en cours)`,
        lot: lotName,
        qty: '',
        unit: '',
        note: s.note || '',
        sortDate: s.entry,
      });
    });
    (p.events || []).forEach(ev => {
      log.push({
        type: eventTypeLabel(ev.type),
        entryDate: ev.date,
        exitDate: '',
        duration: '',
        durationStr: '',
        lot: '',
        qty: typeof ev.qty === 'number' ? ev.qty : '',
        unit: ev.unit || '',
        note: ev.note || '',
        sortDate: ev.date,
      });
    });
    log.sort((a, b) => (a.sortDate || '').localeCompare(b.sortDate || ''));
    return log;
  }

  // Per-parcelle subtotal: sum quantities by event type+unit, plus total grazing days per lot
  function buildSubtotal(p) {
    const totals = {}; // key: "type|unit" -> { type, unit, total, count }
    (p.events || []).forEach(ev => {
      if (typeof ev.qty !== 'number' || isNaN(ev.qty)) return;
      const key = ev.type + '|' + (ev.unit || '');
      if (!totals[key]) totals[key] = { type: eventTypeLabel(ev.type), unit: ev.unit || '', total: 0, count: 0 };
      totals[key].total += ev.qty;
      totals[key].count += 1;
    });
    // Grazing days per lot
    const grazingByLot = {};
    (p.sejours || []).forEach(s => {
      const dur = s.exit ? daysBetween(s.entry, s.exit) : daysBetween(s.entry, todayISO());
      const lotName = s.lotId ? (getLot(s.lotId)?.name || 'Troupeau') : 'Troupeau';
      grazingByLot[lotName] = (grazingByLot[lotName] || 0) + dur;
    });
    return { totals, grazingByLot };
  }

  // Group parcelles by usage, sort by usage order then alpha
  const grouped = {};
  USAGE_ORDER.forEach(u => grouped[u] = []);
  state.parcelles.forEach(p => {
    const u = p.usage || 'pature';
    if (!grouped[u]) grouped[u] = [];
    grouped[u].push(p);
  });
  Object.keys(grouped).forEach(u => grouped[u].sort((a, b) => a.name.localeCompare(b.name)));

  // ============== BUILD ROWS ==============
  // Columns: Parcelle | Surface (ha) | Usage | Type | Date entrée | Date sortie | Durée (j) | Lot | Quantité | Unité | Note
  const COLS = 11;
  const HEADERS = ['Parcelle', 'Surface (ha)', 'Usage', 'Type', 'Date entrée', 'Date sortie', 'Durée (j)', 'Lot', 'Quantité', 'Unité', 'Note'];

  const rows = [];
  const styles = []; // { r, c, style }
  const merges = [];

  // Title row
  rows.push(['Suivi de pâturage — Export du ' + formatDate(todayISO())]);
  styles.push({ r: 0, range: { c0: 0, c1: COLS - 1 }, style: {
    font: { bold: true, sz: 14, color: { rgb: 'FFFFFF' } },
    fill: { patternType: 'solid', fgColor: { rgb: '3A5A40' } },
    alignment: { horizontal: 'center', vertical: 'center' },
  }});
  merges.push({ s: { r: 0, c: 0 }, e: { r: 0, c: COLS - 1 } });
  rows.push([]);

  // Column headers row
  const headerRowIdx = rows.length;
  rows.push(HEADERS);
  styles.push({ r: headerRowIdx, range: { c0: 0, c1: COLS - 1 }, style: {
    font: { bold: true, sz: 11, color: { rgb: 'FFFFFF' } },
    fill: { patternType: 'solid', fgColor: { rgb: '444441' } },
    alignment: { horizontal: 'left', vertical: 'center' },
    border: thinBorder('FFFFFF'),
  }});

  // Iterate by usage group
  USAGE_ORDER.forEach(usage => {
    const list = grouped[usage] || [];
    if (list.length === 0) return;
    const colors = USAGE_COLORS[usage];

    list.forEach(p => {
      const log = buildLog(p);
      const sub = buildSubtotal(p);

      const cellStyle = {
        font: { color: { rgb: colors.text }, sz: 10 },
        fill: { patternType: 'solid', fgColor: { rgb: colors.fill } },
        alignment: { vertical: 'center', wrapText: true },
        border: thinBorder('FFFFFF'),
      };
      const cellStyleRight = Object.assign({}, cellStyle, {
        alignment: { horizontal: 'right', vertical: 'center' },
      });

      if (log.length === 0) {
        // Single row: parcelle info, no events
        const r = rows.length;
        rows.push([p.name, parseFloat(p.surface.toFixed(2)), colors.label, '(aucun événement)', '', '', '', '', '', '', p.note || '']);
        for (let c = 0; c < COLS; c++) {
          const s = (c === 8) ? cellStyleRight : cellStyle;
          styles.push({ r, c, style: c === 3 ? Object.assign({}, s, { font: Object.assign({}, s.font, { italic: true }) }) : s });
        }
      } else {
        log.forEach((entry, i) => {
          const r = rows.length;
          rows.push([
            i === 0 ? p.name : '',
            i === 0 ? parseFloat(p.surface.toFixed(2)) : '',
            i === 0 ? colors.label : '',
            entry.type,
            entry.entryDate ? formatDate(entry.entryDate) : '',
            entry.exitDate ? formatDate(entry.exitDate) : (entry.type === 'Pâturage' && !entry.exitDate ? 'en cours' : ''),
            entry.duration === '' ? '' : entry.duration,
            entry.lot,
            entry.qty,
            entry.unit,
            entry.note,
          ]);
          for (let c = 0; c < COLS; c++) {
            let s = (c === 8) ? cellStyleRight : cellStyle;
            // Bold the parcelle name on first row
            if (i === 0 && c === 0) {
              s = Object.assign({}, s, { font: Object.assign({}, s.font, { bold: true }) });
            }
            // Italic "en cours"
            if (c === 5 && entry.type === 'Pâturage' && !entry.exitDate) {
              s = Object.assign({}, s, { font: Object.assign({}, s.font, { italic: true }) });
            }
            styles.push({ r, c, style: s });
          }
        });
      }

      // Subtotal row
      const subParts = [];
      Object.values(sub.totals).forEach(t => {
        const totVal = t.total >= 10 ? t.total.toFixed(1) : t.total.toFixed(2).replace(/\.?0+$/, '');
        subParts.push(`${t.type} : ${totVal}${t.unit ? ' ' + t.unit : ''} (${t.count}×)`);
      });
      Object.entries(sub.grazingByLot).forEach(([lot, days]) => {
        subParts.push(`Pâturage ${lot} : ${days} j`);
      });
      const subText = subParts.length > 0 ? 'Cumul : ' + subParts.join('  ·  ') : 'Aucun cumul';
      const rSub = rows.length;
      rows.push(['', '', '', subText, '', '', '', '', '', '', '']);
      const subStyle = {
        font: { bold: true, italic: true, color: { rgb: colors.text }, sz: 10 },
        fill: { patternType: 'solid', fgColor: { rgb: colors.accent } },
        alignment: { vertical: 'center' },
        border: thinBorder('FFFFFF'),
      };
      for (let c = 0; c < COLS; c++) {
        styles.push({ r: rSub, c, style: subStyle });
      }
      merges.push({ s: { r: rSub, c: 3 }, e: { r: rSub, c: COLS - 1 } });

      // Empty separator row
      rows.push([]);
    });
  });

  // ============== BUILD WORKSHEET ==============
  const ws = XLSX.utils.aoa_to_sheet(rows);
  ws['!merges'] = merges;
  ws['!cols'] = [
    { wch: 18 }, // Parcelle
    { wch: 11 }, // Surface
    { wch: 9 },  // Usage
    { wch: 18 }, // Type
    { wch: 12 }, // Date entrée
    { wch: 12 }, // Date sortie
    { wch: 9 },  // Durée
    { wch: 12 }, // Lot
    { wch: 9 },  // Quantité
    { wch: 8 },  // Unité
    { wch: 35 }, // Note
  ];

  // Apply styles
  styles.forEach(item => {
    if (item.range) {
      // Range style: apply to all cells in row from c0 to c1
      for (let c = item.range.c0; c <= item.range.c1; c++) {
        const addr = XLSX.utils.encode_cell({ r: item.r, c });
        if (!ws[addr]) ws[addr] = { v: '', t: 's' };
        ws[addr].s = item.style;
      }
    } else {
      const addr = XLSX.utils.encode_cell({ r: item.r, c: item.c });
      if (!ws[addr]) ws[addr] = { v: '', t: 's' };
      ws[addr].s = item.style;
    }
  });

  // Row heights
  ws['!rows'] = ws['!rows'] || [];
  ws['!rows'][0] = { hpt: 24 };
  if (ws['!rows'][headerRowIdx] === undefined) ws['!rows'][headerRowIdx] = { hpt: 22 };

  // Freeze top header rows
  ws['!freeze'] = { xSplit: 0, ySplit: headerRowIdx + 1 };

  // Auto-filter on header row
  const lastRow = rows.length - 1;
  ws['!autofilter'] = { ref: XLSX.utils.encode_range({ s: { r: headerRowIdx, c: 0 }, e: { r: lastRow, c: COLS - 1 } }) };

  const wb = XLSX.utils.book_new();
  XLSX.utils.book_append_sheet(wb, ws, 'Suivi pâturage');

  const filename = `paturage-${todayISO()}.xlsx`;
  XLSX.writeFile(wb, filename);
};


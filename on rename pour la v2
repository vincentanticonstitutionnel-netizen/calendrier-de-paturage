async function handleAuthSubmit(mode) {
  const email = document.getElementById('authEmail').value.trim();
  const password = document.getElementById('authPassword').value;
  const errEl = document.getElementById('authError');
  const btnSignin = document.getElementById('btnSignin');
  const btnSignup = document.getElementById('btnSignup');
  errEl.textContent = '';
  if (!email || !password) {
    errEl.textContent = 'Email et mot de passe requis.';
    return;
  }
  if (password.length < 8) {
    errEl.textContent = 'Mot de passe : 8 caractères minimum.';
    return;
  }
  btnSignin.disabled = true; btnSignup.disabled = true;
  try {
    if (mode === 'signup') {
      await doSignUp(email, password);
      errEl.style.color = 'var(--accent)';
      errEl.textContent = '✓ Compte créé. Vérifiez votre email pour confirmer, puis revenez pour vous connecter.';

function todayISO() { return new Date().toISOString().slice(0, 10); }
function daysBetween(a, b) { return Math.floor((new Date(b) - new Date(a)) / 86400000); }
function escapeHtml(s) {
  return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
}
function getCSS(v) { return getComputedStyle(document.documentElement).getPropertyValue(v).trim(); }
function newId() { return 'p_' + Date.now() + '_' + Math.random().toString(36).slice(2, 7); }

function polygonAreaHa(coords) {
  const latlngs = coords.map(c => L.latLng(c[1], c[0]));
  if (latlngs.length < 3) return 0;
  let area = 0;
  for (let i = 0; i < latlngs.length; i++) {
    const j = (i + 1) % latlngs.length;
    const lat1 = latlngs[i].lat * Math.PI / 180;
    const lat2 = latlngs[j].lat * Math.PI / 180;
    const lon1 = latlngs[i].lng * Math.PI / 180;
    const lon2 = latlngs[j].lng * Math.PI / 180;
    area += (lon2 - lon1) * (2 + Math.sin(lat1) + Math.sin(lat2));
  }
  return Math.abs(area * 6378137 * 6378137 / 2.0) / 10000;
}
function polygonCenter(coords) {
  let lat = 0, lng = 0;
  const n = coords.length;
  const last = n - 1;
  const close = (n > 1 && coords[0][0] === coords[last][0] && coords[0][1] === coords[last][1]);
  const count = close ? n - 1 : n;
  for (let i = 0; i < count; i++) { lng += coords[i][0]; lat += coords[i][1]; }
  return [lat / count, lng / count];
}
function ensureClosed(ring) {
  if (ring.length === 0) return ring;
  const a = ring[0], b = ring[ring.length - 1];
  if (a[0] !== b[0] || a[1] !== b[1]) ring.push([a[0], a[1]]);
  return ring;
}
function unclose(ring) {
  if (ring.length > 1) {
    const a = ring[0], b = ring[ring.length - 1];
    if (a[0] === b[0] && a[1] === b[1]) return ring.slice(0, -1);
  }
  return ring;
}

function parcelStatus(p) {
  if (!p.sejours || p.sejours.length === 0) return { state: 'available', days: null, lastSejour: null, lotId: null };
  const last = p.sejours[p.sejours.length - 1];
  if (!last.exit) return { state: 'grazing', days: daysBetween(last.entry, todayISO()), lastSejour: last, lotId: last.lotId };
  const restDays = daysBetween(last.exit, todayISO());
  if (restDays >= state.settings.restDays) return { state: 'available', days: restDays, lastSejour: last, lotId: null };
  return { state: 'rest', days: restDays, lastSejour: last, lotId: null };
}
function statusColor(s, lotId) {
  if (s === 'grazing' && lotId) return lotColor(lotId);
  return s === 'grazing' ? getCSS('--grazing')
       : s === 'rest'    ? getCSS('--rest')
       : getCSS('--available');
}

const parcelLayer = L.featureGroup().addTo(map);
const labelLayer = L.layerGroup().addTo(map);

function renderParcelles() {
  parcelLayer.clearLayers();
  labelLayer.clearLayers();
  const showLotBadge = state.lots.length > 1;
  state.parcelles.forEach(p => {
    const status = parcelStatus(p);
    let color = statusColor(status.state, status.lotId);
    let weight = 2, fillOpacity = 0.35;
    // Highlight if currently selected for merge
    if (mergeSelectActive && mergeSelection.includes(p.id)) {
      color = getCSS('--edit'); weight = 4; fillOpacity = 0.5;
    } else if (selectedParcelId === p.id) {
      // First-tap highlight
      weight = 5; fillOpacity = 0.6;
    }
    const polygon = L.polygon(p.coords.map(c => [c[1], c[0]]), {
      color: color, weight: weight, fillColor: color, fillOpacity: fillOpacity,
    });
    polygon.parcelId = p.id;
    polygon.on('click', (e) => {
      L.DomEvent.stopPropagation(e);
      if (mergeSelectActive) { toggleMergeSelection(p.id); return; }
      if (mode !== 'idle') return;
      // Two-tap selection: first tap highlights, second tap opens
      if (selectedParcelId !== p.id) {
        selectedParcelId = p.id;
        renderParcelles();
        return;
      }
      // Second tap: open
      selectedParcelId = null;
      renderParcelles();
      if (uiMode === 'edit') {
        openParcelleEdit(p.id);
      } else {
        openParcelle(p.id);
      }
    });
    parcelLayer.addLayer(polygon);
    const center = polygonCenter(p.coords);
    let badge = '';
    if (showLotBadge && status.state === 'grazing' && status.lotId) {
      const lot = getLot(status.lotId);
      if (lot) badge = ` <span style="background:${lot.color};color:#fff;padding:0 4px;border-radius:3px;font-size:9px">${escapeHtml(lot.name)}</span>`;
    }
    const labelHtml = `<div class="parcelle-label">${escapeHtml(p.name)}${badge}</div>`;
    labelLayer.addLayer(L.marker(center, {
      icon: L.divIcon({ html: labelHtml, className: '', iconSize: null }),
      interactive: false,
    }));
  });
}


window.renderList = function(filter) {
  const filtered = (filter === 'all')
    ? state.parcelles.slice()
    : state.parcelles.filter(p => (p.usage || 'pature') === filter);
  const sorted = filtered.sort((a, b) => {
    const sa = parcelStatus(a).state, sb = parcelStatus(b).state;
    const order = { grazing: 0, rest: 1, available: 2 };
    if (order[sa] !== order[sb]) return order[sa] - order[sb];
    return a.name.localeCompare(b.name);
  });

  const items = sorted.map(p => {
    const s = parcelStatus(p);
    const color = statusColor(s.state, s.lotId);
    const label = s.state === 'grazing' ? (s.lotId && state.lots.length > 1 ? `${escapeHtml(getLot(s.lotId).name)} ${s.days}j` : `Pâturée ${s.days}j`)
                : s.state === 'rest'    ? `Repos ${s.days}j`
                : s.lastSejour ? `Dispo (${s.days}j)` : 'Vierge';
    const usageBadge = `<span style="font-size:10px;background:var(--line);padding:1px 5px;border-radius:3px;color:var(--ink);">${USAGE_LABELS[p.usage] || 'Pâture'}</span>`;
    const evCount = (p.events || []).length;
    const evStr = evCount > 0 ? ` · ${evCount} évén.` : '';
    return `
      <div class="sejour" style="cursor:pointer;border-left:3px solid ${color};" onclick="openParcelle('${p.id}')">
        <div>
          <strong>${escapeHtml(p.name)}</strong> ${usageBadge}
          <div class="sejour-meta">${p.surface.toFixed(2)} ha · ${label}${evStr}</div>
        </div>
        <div style="font-size:18px;color:${color}">›</div>
      </div>
    `;
  }).join('');

  // Counts per usage
  const counts = { all: state.parcelles.length };
  Object.keys(USAGE_LABELS).forEach(u => counts[u] = 0);
  state.parcelles.forEach(p => { counts[p.usage || 'pature'] = (counts[p.usage || 'pature'] || 0) + 1; });

  const filterBtn = (key, label) => {
    if (key !== 'all' && !counts[key]) return '';
    const active = filter === key;
    return `<button onclick="renderList('${key}')" style="flex:0 1 auto;padding:6px 10px;font-size:12px;${active ? 'background:var(--accent);color:#fff;border-color:var(--accent-dark);' : ''}">${label} (${counts[key] || 0})</button>`;
  };

  // Surface totals (only filtered)
  const totalHa = filtered.reduce((s, p) => s + p.surface, 0).toFixed(2);

  openModal(`
    <h2>Mes parcelles</h2>
    <div class="modal-actions" style="margin-top:0;margin-bottom:8px">
      ${filterBtn('all', 'Toutes')}
      ${filterBtn('pature', 'Pâture')}
      ${filterBtn('foin', 'Foin')}
      ${filterBtn('mixte', 'Mixte')}
      ${filterBtn('culture', 'Culture')}
      ${filterBtn('autre', 'Autre')}
    </div>
    <div class="info-card">${filtered.length} parcelle(s) · <strong>${totalHa} ha</strong></div>
    ${items || '<div class="empty-msg">Aucune parcelle dans cette catégorie.</div>'}
    <div class="modal-actions"><button onclick="closeModal()">Fermer</button></div>
  `);
};


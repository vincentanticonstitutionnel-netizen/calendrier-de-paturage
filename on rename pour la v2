                    : status.lastSejour ? `✓ Disponible (repos ${status.days} j)` : '✓ Jamais pâturée';

  const sejoursHtml = (p.sejours.length === 0)
    ? '<div class="empty-msg">Aucun séjour enregistré.</div>'
    : p.sejours.slice().reverse().map((s, idx) => {
        const realIdx = p.sejours.length - 1 - idx;
        const isCurrent = !s.exit;
        const dur = s.exit ? daysBetween(s.entry, s.exit) : daysBetween(s.entry, todayISO());
        const lotTag = (state.lots.length > 1 && s.lotId) ? `<span style="background:${lotColor(s.lotId)};color:#fff;padding:1px 5px;border-radius:3px;font-size:10px;margin-right:4px">${escapeHtml(getLot(s.lotId).name)}</span>` : '';
        return `
          <div class="sejour ${isCurrent ? 'sejour-current' : ''}">
            <div>
              <div class="sejour-dates">${lotTag}${formatDate(s.entry)} → ${s.exit ? formatDate(s.exit) : '<em>en cours</em>'}</div>
              <div class="sejour-meta">${dur} jour${dur > 1 ? 's' : ''}${s.note ? ' · ' + escapeHtml(s.note) : ''}</div>
            </div>
            <button class="sejour-del" onclick="deleteSejour('${p.id}', ${realIdx})" title="Supprimer">×</button>
          </div>
        `;
      }).join('');

  // Events list (most recent first)
  const eventsSorted = (p.events || []).slice().sort((a, b) => (b.date || '').localeCompare(a.date || ''));
  const eventsHtml = eventsSorted.length === 0
    ? '<div class="empty-msg">Aucun événement enregistré.</div>'
    : eventsSorted.map(ev => {
        const qtyStr = (typeof ev.qty === 'number' && !isNaN(ev.qty))
          ? ` · <strong>${ev.qty}${ev.unit ? ' ' + escapeHtml(ev.unit) : ''}</strong>`
          : '';
        return `
          <div class="sejour">
            <div>
              <div class="sejour-dates">${eventTypeIcon(ev.type)} ${formatDate(ev.date)} — ${escapeHtml(eventTypeLabel(ev.type))}${qtyStr}</div>
              ${ev.note ? `<div class="sejour-meta">${escapeHtml(ev.note)}</div>` : ''}
            </div>
            <button class="sejour-del" onclick="deleteEvent('${p.id}', '${ev.id}')" title="Supprimer">×</button>
          </div>
        `;
      }).join('');

  // Annual summary (last 3 years)
  const summary = annualSummary(p.events || []);
  const years = Object.keys(summary).sort().reverse().slice(0, 3);
  const summaryHtml = years.length === 0 ? '' : `
    <label>Récap annuel</label>
    ${years.map(y => {
      const types = Object.keys(summary[y]);
      const lines = types.map(t => {
        const s = summary[y][t];
        const qty = s.total > 0
          ? `${s.total.toFixed(s.total >= 10 ? 1 : 2).replace(/\.?0+$/, '')}${s.unit ? ' ' + s.unit : ''}${s.mixed ? ' *' : ''}`
          : `${s.count} fois`;
        return `${eventTypeIcon(t)} ${eventTypeLabel(t)} : <strong>${qty}</strong>${s.count > 1 && s.total > 0 ? ` (${s.count}×)` : ''}`;
      }).join('<br>');
      return `<div class="info-card"><strong>${y}</strong><br>${lines}</div>`;
    }).join('')}
  `;

  const actionBtn = status.state === 'grazing'
    ? `<button class="warn" onclick="endSejour('${p.id}')">Sortir le troupeau</button>`
    : `<button class="primary" onclick="startSejour('${p.id}')">Entrée du troupeau</button>`;

  openModal(`
    <h2>${escapeHtml(p.name)}</h2>
    <div class="info-card">
      ${statusLabel}<br>
      <strong>${p.surface.toFixed(2)} ha</strong> · Usage : <strong>${USAGE_LABELS[p.usage] || 'Pâture'}</strong>
      ${p.note ? '<br><em>' + escapeHtml(p.note) + '</em>' : ''}
    </div>

    ${summaryHtml}

    <label>Pâturage</label>
    <div class="sejours">${sejoursHtml}</div>
    <div class="modal-actions">
      ${actionBtn}
    </div>

    <label>Foin / fauche / autres événements</label>
    <div class="sejours">${eventsHtml}</div>
    <div class="modal-actions">
      <button class="primary" onclick="addEvent('${p.id}')">+ Ajouter un événement</button>
    </div>

    <div class="modal-actions" style="margin-top:24px">
      <button onclick="editParcelleInfo('${p.id}')">Renommer / usage</button>
      <button onclick="zoomToParcelle('${p.id}')">Centrer</button>
    </div>
    <div class="modal-actions">
      <button onclick="closeModal()">Fermer</button>
    </div>
  `);
};

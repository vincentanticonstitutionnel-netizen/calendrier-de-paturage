function formatDate(iso) {
  if (!iso) return '';
  const [y, m, d] = iso.split('-');
  return `${d}/${m}/${y.slice(2)}`;
}

window.startSejour = function(id) {
  const p = state.parcelles.find(x => x.id === id);
  if (!p) return;
  const multiLot = state.lots.length > 1;
  // Build lot selector ; default = first lot, or the lot currently grazing somewhere if any
  const lotOptions = state.lots.map(l => {
    const cur = currentParcelForLot(l.id);
    const curInfo = cur ? ` (actuellement sur ${escapeHtml(cur.parcelle.name)})` : '';
    return `<option value="${l.id}">${escapeHtml(l.name)}${curInfo}</option>`;
  }).join('');

  openModal(`
    <h2>Entrée du troupeau</h2>
    <div class="info-card"><strong>${escapeHtml(p.name)}</strong></div>
    ${multiLot ? `
      <label>Lot</label>
      <select id="sejourLot" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:6px;font-size:16px;font-family:inherit;background:var(--bg);color:var(--ink);">
        ${lotOptions}
      </select>
    ` : `<input type="hidden" id="sejourLot" value="${state.lots[0].id}">`}
    <label>Date d'entrée</label>
    <input type="date" id="sejourDate" value="${todayISO()}">
    <label>Note (facultatif)</label>
    <input type="text" id="sejourNote" placeholder="ex: 18 vaches + veaux">
    <div id="autoExitInfo" style="display:none" class="info-card"></div>
    <div class="modal-actions">
      <button onclick="openParcelle('${p.id}')">Annuler</button>
      <button class="primary" onclick="confirmStartSejour('${p.id}')">Valider</button>
    </div>
  `);

  // Show auto-exit hint when lot selection changes
  const lotSel = document.getElementById('sejourLot');
  const dateInp = document.getElementById('sejourDate');
  const info = document.getElementById('autoExitInfo');
  function refreshHint() {
    const lotId = lotSel.value;
    const cur = currentParcelForLot(lotId);
    if (cur && cur.parcelle.id !== id) {
      info.style.display = '';
      info.innerHTML = `⓵ Le lot <strong>${escapeHtml(getLot(lotId).name)}</strong> est actuellement sur <strong>${escapeHtml(cur.parcelle.name)}</strong>. Sa sortie sera enregistrée automatiquement à la même date.`;
    } else {
      info.style.display = 'none';
    }
  }
  if (lotSel.tagName === 'SELECT') lotSel.addEventListener('change', refreshHint);
  dateInp.addEventListener('change', refreshHint);
  refreshHint();
};

window.confirmStartSejour = function(id) {
  const p = state.parcelles.find(x => x.id === id);
  const lotId = document.getElementById('sejourLot').value;
  const date = document.getElementById('sejourDate').value;
  const note = document.getElementById('sejourNote').value.trim();
  if (!date) return alert('Date requise');

  // Auto-exit: if this lot is currently grazing somewhere else, close it
  const cur = currentParcelForLot(lotId);
  if (cur && cur.parcelle.id !== id) {
    if (date < cur.sejour.entry) {
      return alert(`Date d'entrée antérieure à l'entrée actuelle du lot sur ${cur.parcelle.name} (${formatDate(cur.sejour.entry)}).`);
    }
  } else if (cur && cur.parcelle.id === id) {
    return alert('Ce lot est déjà sur cette parcelle.');
  }

  snapshotState(`Entrée du troupeau sur « ${p.name} »`);
  // Re-fetch in case (parcelles array unchanged so reference still valid; but cur ref also still valid)
  if (cur && cur.parcelle.id !== id) {
    cur.sejour.exit = date;
  }
  p.sejours.push({ entry: date, exit: null, note, lotId });
  saveData(); renderParcelles(); closeModal();
};

window.endSejour = function(id) {
  const p = state.parcelles.find(x => x.id === id);
  const last = p.sejours[p.sejours.length - 1];
  if (!last || last.exit) return;
  openModal(`
    <h2>Sortie du troupeau</h2>
    <div class="info-card"><strong>${escapeHtml(p.name)}</strong><br>
    Entrée le ${formatDate(last.entry)}</div>
    <label>Date de sortie</label>
    <input type="date" id="sejourExit" value="${todayISO()}" min="${last.entry}">
    <div class="modal-actions">
      <button onclick="openParcelle('${p.id}')">Annuler</button>
      <button class="primary" onclick="confirmEndSejour('${p.id}')">Valider</button>
    </div>
  `);
};
window.confirmEndSejour = function(id) {
  const p = state.parcelles.find(x => x.id === id);
  const last = p.sejours[p.sejours.length - 1];
  const date = document.getElementById('sejourExit').value;
  if (!date) return alert('Date requise');
  if (date < last.entry) return alert('La date de sortie doit être ≥ entrée');
  snapshotState(`Sortie du troupeau de « ${p.name} »`);
  last.exit = date;
  saveData(); renderParcelles(); closeModal();
};

window.deleteSejour = function(id, idx) {
  if (!confirm('Supprimer ce séjour ?')) return;
  const p = state.parcelles.find(x => x.id === id);
  p.sejours.splice(idx, 1);
  saveData(); renderParcelles(); openParcelle(id);
};


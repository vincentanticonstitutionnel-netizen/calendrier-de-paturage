window.saveRenameLot = function(id) {
  const l = state.lots.find(x => x.id === id);
  l.name = document.getElementById('renLotName').value.trim() || l.name;
  l.color = document.getElementById('renLotColor').value;
  saveData();
  renderParcelles();
  openLots();
};

window.deleteLot = function(id) {
  const l = state.lots.find(x => x.id === id);
  if (!l) return;
  // Check no current grazing
  if (currentParcelForLot(id)) return alert('Ce lot est actuellement en pâture, sortez-le d\'abord.');
  // Count past sejours referencing this lot
  let count = 0;
  state.parcelles.forEach(p => (p.sejours || []).forEach(s => { if (s.lotId === id) count++; }));
  const msg = count > 0
    ? `Ce lot est associé à ${count} séjour(s) passé(s). Si vous le supprimez, ces séjours seront réassignés au lot par défaut "${state.lots.find(x => x.id !== id).name}". Continuer ?`
    : 'Supprimer ce lot ?';
  if (!confirm(msg)) return;
  const fallback = state.lots.find(x => x.id !== id).id;
  state.parcelles.forEach(p => (p.sejours || []).forEach(s => { if (s.lotId === id) s.lotId = fallback; }));
  state.lots = state.lots.filter(x => x.id !== id);
  saveData();
  renderParcelles();
  openLots();
};


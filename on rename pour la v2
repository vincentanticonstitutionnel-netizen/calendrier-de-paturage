document.getElementById('btnLocate').onclick = () => {
  if (!navigator.geolocation) {
    alert('La géolocalisation n\'est pas disponible sur ce navigateur.');
    return;
  }
  // Use navigator.geolocation directly to get a more useful error code
  navigator.geolocation.getCurrentPosition(
    pos => {
      const ll = L.latLng(pos.coords.latitude, pos.coords.longitude);
      map.setView(ll, 17);
      if (locMarker) map.removeLayer(locMarker);
      locMarker = L.circleMarker(ll, {
        radius: 8, color: '#1a73e8', fillColor: '#1a73e8', fillOpacity: 0.6, weight: 2
      }).addTo(map);
    },
    err => {
      let msg;
      if (err.code === 1) {
        msg = 'Permission refusée. Dans Chrome, touchez le cadenas/⓵ à gauche de l\'URL → Autorisations → activez « Localisation ». Recharger la page après.';
      } else if (err.code === 2) {
        msg = 'Position indisponible. Vérifiez que la localisation système (GPS) est activée dans les paramètres Android. Si vous êtes en intérieur, sortez ou attendez quelques secondes.';
      } else if (err.code === 3) {
        msg = 'Délai dépassé. Le GPS met parfois 30 s à accrocher en plein air. Réessayez.';
      } else {
        msg = 'Erreur GPS : ' + (err.message || 'inconnue');
      }
      alert(msg);
    },
    { enableHighAccuracy: true, timeout: 30000, maximumAge: 60000 }
  );
};
